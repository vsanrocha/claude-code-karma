{
  "name": "karma-logger",
  "version": "0.1.0",
  "description": "Local metrics and cost tracking for Claude Code sessions",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "karma": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "metrics",
    "cost-tracking",
    "cli",
    "ai",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/karma-logger.git"
  },
  "bugs": {
    "url": "https://github.com/anthropics/karma-logger/issues"
  },
  "homepage": "https://github.com/anthropics/karma-logger#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.7",
    "@inkjs/ui": "^2.0.0",
    "asciichart": "^1.5.25",
    "better-sqlite3": "^12.5.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.2",
    "hono": "^4.11.3",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/asciichart": "^1.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
